# ── Runtime data (per-user, never commit) ─────────────────────
# The whole data/ dir is local state: DB, waveform cache, browser
# profile (cookies!), repair history, scraped tracklists, backups,
# embedding cache. Excluded entirely — config.json is rebuilt from
# DEFAULTS on first launch.
data/
downloads/

# ── Secrets (defence in depth) ────────────────────────────────
# Spotify creds now live in Windows Credential Manager (keyring), but
# legacy installs may have plaintext fallbacks here. Keep them out.
*.env
*.secret
*.bak

# ── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
ENV/

# Test + coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ── IDE / editor ───────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Claude Code session state ──────────────────────────────────
# Commit the SHARED project config (settings.json + CLAUDE.md is at
# repo root) so collaborators inherit hooks + conventions. Exclude the
# machine-local files (transcripts, IDE state, user-private allows).
.claude/*
!.claude/settings.json
!.claude/agents/
!.claude/commands/
.cache

# ── Local diagnostic scripts (workspace tools, not features) ───
# Standalone helpers we use during a session to probe the running
# system. Useful but per-machine — keep out of git.
_check_*.py
_scrape_dump.html
_tracklist_dump.html
_tl_response.html
_gh_search.py

# ── PyInstaller artefacts ──────────────────────────────────────
# (the spec file IS committed — only the build outputs are excluded)
*.exe
*.app
build/
dist/
