{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "// description": "Project-level Claude Code config (committed). For machine-local overrides see settings.local.json.",

  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git stash list)",
      "Bash(python -m pytest*)",
      "Bash(python -m tests.test_smoke)",
      "Bash(python run.py)",
      "Bash(python _check_*.py)",
      "Bash(pip show *)",
      "Bash(pip list*)",
      "Bash(ruff check *)",
      "Bash(ruff format --check *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force origin main*)",
      "Bash(git reset --hard origin/*)"
    ]
  },

  "hooks": {
    "// PostWrite": "Auto-format Python files after Write/Edit. Ruff format is fast (<50ms per file) and idempotent. Silent on success, non-blocking on failure.",
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ruff format \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
